# ---------- BoxNow Shipping ----------
# Stage credentials (replace with production values for go-live):
BOXNOW_CLIENT_ID=
BOXNOW_CLIENT_SECRET=
BOXNOW_PARTNER_ID=
BOXNOW_WAREHOUSE_ID=2
BOXNOW_WEBHOOK_SECRET=
BOXNOW_API_BASE_URL=https://api-stage.boxnow.gr
BOXNOW_LOCATION_API_BASE_URL=https://locationapi-stage.boxnow.gr
BOXNOW_LIVE_MODE=False
BOXNOW_DEFAULT_COMPARTMENT_SIZE=1
# Shipping price + free-shipping threshold are admin-tunable through the
# Django admin (`extra_settings` rows BOXNOW_SHIPPING_PRICE /
# BOXNOW_FREE_SHIPPING_THRESHOLD), not env vars.
BOXNOW_HTTP_TIMEOUT=10
# Operations phone BoxNow calls for pickup issues at the origin warehouse.
# Must be in international format (BoxNow API rejects malformed phones).
BOXNOW_NOTIFY_PHONE=+302100000000

# ---------- ACS Shipping ----------
# Stage credentials (rotate for production). NOTE: ACS_BILLING_CODE
# may contain Greek characters (e.g. "2ΑΚ89587" with Greek capital ΑΚ);
# ensure this file is saved UTF-8.
ACS_API_KEY=
ACS_COMPANY_ID=
ACS_COMPANY_PASSWORD=
ACS_USER_ID=
ACS_USER_PASSWORD=
ACS_BILLING_CODE=
ACS_API_BASE_URL=https://webservices.acscourier.net/ACSRestServices/api/ACSAutoRest
ACS_HTTP_TIMEOUT=15
ACS_LIVE_MODE=False
ACS_PICKUP_LIST_TIMEZONE=Europe/Athens
# CSV of supported ISO-3166-1 alpha-2 country codes (e.g. "GR,CY").
ACS_SUPPORTED_COUNTRIES=GR
# Pricing is admin-tunable through Django admin
# (`extra_settings.Setting` rows ACS_SHIPPING_PRICE /
# ACS_FREE_SHIPPING_THRESHOLD). The on/off switch is the
# ShippingProvider.is_active flag, NOT an env var.

# ---------- Meta Conversions API ----------
# META_PIXEL_ID is the public Pixel ID (also exposed to Nuxt via
# NUXT_PUBLIC_SCRIPTS_META_PIXEL_ID for the browser tag). The CAPI
# access token is a server-only secret — provision a long-lived
# system-user token in Events Manager → Settings → Conversions API.
# The master kill switch (META_CAPI_ENABLED) lives in extra_settings,
# not here, so ops can flip it without a redeploy.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_API_VERSION=v22.0
# Set during integration testing to flag every event as a Test Event
# in Events Manager. MUST be empty in production.
META_CAPI_TEST_EVENT_CODE=
META_CAPI_PARTNER_AGENT=grooveshop-django-capi-1.0
META_CAPI_HTTP_TIMEOUT=10
